#!/usr/bin/env bash
set -euo pipefail

# Template: repo-specific Ralph helper script.
# Copy this file to scripts/ralph/<your-helper>.sh and customize.
# Then reference the helper in scripts/ralph/prompt.local.md.

usage() {
  cat <<'EOF2'
Usage: ./scripts/ralph/<your-helper>.sh [options]

Guidelines:
- Keep behavior idempotent (safe to run repeatedly).
- Print concise key=value style output when used by prompts.
- Exit non-zero on real failures.
EOF2
}

if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
  usage
  exit 0
fi

# Example output format for prompt-driven helpers.
echo "status=ok"
echo "message=replace_with_repo_specific_logic"
